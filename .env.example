# ============================================================
# Unified Agent Gateway (UAG) - Environment Variables
# ============================================================
# Copy this file to .env and configure for your environment
# DO NOT commit .env to version control with secrets
# ============================================================

# ----------------------------------------------------------------
# Server Configuration
# ----------------------------------------------------------------
UAG_HOST=0.0.0.0
UAG_PORT=8000
UAG_DEBUG=false

# ----------------------------------------------------------------
# Security (REQUIRED - change in production)
# ----------------------------------------------------------------
UAG_MGMT_SECRET=your-secure-secret-here
API_TOKEN=your-secure-api-token-here

# ----------------------------------------------------------------
# Database
# ----------------------------------------------------------------
UAG_DATABASE_PATH=/data/codara.db

# ----------------------------------------------------------------
# Workspaces
# ----------------------------------------------------------------
UAG_WORKSPACES_ROOT=/workspaces

# ----------------------------------------------------------------
# Redis (for production session locks)
# ----------------------------------------------------------------
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ----------------------------------------------------------------
# PostgreSQL (optional - uncomment for production)
# ----------------------------------------------------------------
# POSTGRES_PORT=5432
# POSTGRES_PASSWORD=your-secure-postgres-password

# ----------------------------------------------------------------
# Provider Credentials (optional)
# ----------------------------------------------------------------
UAG_CODEX_BILLING_API_KEY=
UAG_CODEX_USAGE_ENDPOINTS=https://chatgapt.com/backend-api/wham/usage,https://api.openai.com/dashboard/codex/usage
UAG_GEMINI_BILLING_API_KEY=

# ----------------------------------------------------------------
# Compression Settings
# ----------------------------------------------------------------
UAG_COMPRESSION_THRESHOLD=64000
UAG_COMPRESSION_MODEL=gpt-4o-mini

# ----------------------------------------------------------------
# Concurrency Settings
# ----------------------------------------------------------------
UAG_MAX_CONCURRENCY=10
UAG_SESSION_TTL_HOURS=24

# ----------------------------------------------------------------
# Rate Limits (defaults)
# ----------------------------------------------------------------
UAG_DEFAULT_TPM_LIMIT=100000
UAG_DEFAULT_RPD_LIMIT=5000
UAG_DEFAULT_HOURLY_LIMIT=50000
UAG_DEFAULT_WEEKLY_LIMIT=1000000

# ----------------------------------------------------------------
# Nginx (optional - for SSL termination)
# ----------------------------------------------------------------
# NGINX_PORT=80
# NGINX_SSL_PORT=443
