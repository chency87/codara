# Codara Docker deployment environment.
# Copy to .env and replace secrets before running docker compose.

# Published host port. The container always listens on 8000.
CODARA_HTTP_PORT=8000
AMESH_IMAGE=amesh:latest

# Provider CLI package specs used at image build time. Pin exact versions for
# reproducible releases, or keep @latest for local builds.
CODEX_CLI_PACKAGE=@openai/codex@latest
GEMINI_CLI_PACKAGE=@google/gemini-cli@latest
OPENCODE_CLI_PACKAGE=opencode-ai@latest
PNPM_PACKAGE=pnpm@latest
NODE_VERSION=24
NVM_VERSION=0.40.3

# Required operator secret used by dashboard login and management APIs.
API_TOKEN=replace-with-a-long-random-secret

# Runtime paths inside the container. Keep these aligned with docker-compose.yml.
UAG_DATABASE_PATH=/data/amesh.db
UAG_WORKSPACES_ROOT=/workspaces
UAG_LOGS_ROOT=/logs
UAG_CONFIG_PATH=/config/amesh.toml
UAG_CONFIG_DIR=/config
UAG_CLI_CAPTURE_ENABLED=true
UAG_CLI_CAPTURE_ROOT=cli-runs

# Redis is local to the compose network by default.
REDIS_URL=redis://redis:6379/0

# Provider behavior.
UAG_CODEX_STALL_TIMEOUT_SECONDS=600
UAG_GEMINI_STALL_TIMEOUT_SECONDS=600
UAG_OPENCODE_STALL_TIMEOUT_SECONDS=600

# Optional release update checks.
UAG_RELEASE_CHECK_ENABLED=false
# UAG_RELEASE_REPOSITORY=your-org/codara

# Optional service names.
AMESH_CONTAINER_NAME=amesh
CODARA_REDIS_CONTAINER_NAME=codara-redis
